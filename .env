# Server Settings
PORT=5000
NODE_ENV=development

# Database Settings
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/skylake_automation
# MONGODB_URI=mongodb://127.0.0.1:27017/skylake_automation
MONGODB_URI=mongodb://localhost:27017/skylake_automation

# JWT Settings
JWT_SECRET=super-secure-admin-session-secret-key-987654321
JWT_EXPIRE=24h

# Cloudinary Settings (Optional, system falls back to secure local storage if left empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

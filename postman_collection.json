      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:5000/api/admin/login",
              "protocol": "http",
              "host": ["127.0.0.1"],
              "port": "5000",
              "path": ["api", "admin", "login"]
            },
            "description": "Exchanges admin credentials for a JWT token. Also sets a hardened cookie."
          }
        },
        {
